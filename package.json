{
  "name": "telegram-channel-manager",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/_core/index.ts",
    "dev:client": "cd client && vite",
    "build": "npm run build:client && npm run build:server",
    "build:client": "cd client && npm install && tsc && vite build",
    "build:server": "tsc -p server/tsconfig.json",
    "start": "node dist/server/_core/index.js",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "check": "tsc --noEmit -p server/tsconfig.json && cd client && tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.33.1",
    "@fal-ai/client": "^1.2.0",
    "@trpc/server": "^11.0.0-rc.666",
    "@trpc/client": "^11.0.0-rc.666",
    "@trpc/react-query": "^11.0.0-rc.666",
    "@tanstack/react-query": "^5.62.11",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.3",
    "express": "^4.21.2",
    "node-cron": "^3.0.3",
    "postgres": "^3.4.5",
    "telegraf": "^4.16.3",
    "zod": "^3.24.1",
    "pdf-parse": "^1.1.1",
    "mammoth": "^1.8.0",
    "axios": "^1.7.9"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "@types/pdf-parse": "^1.1.4",
    "concurrently": "^9.1.0",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
